<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="320dp"
    android:clipToPadding="false">

    <!-- Full-bleed banner image -->
    <ImageView
        android:id="@+id/carouselBanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        tools:ignore="ContentDescription"
        tools:src="@tools:sample/backgrounds/scenic" />

    <!-- Dark gradient so text is always readable -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/linear_gradient_bg" />

    <!-- Content overlay pinned to the bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="16dp">

        <!-- TMDB logo art (replaces text title when available) -->
        <ImageView
            android:id="@+id/carouselLogo"
            android:layout_width="180dp"
            android:layout_height="60dp"
            android:scaleType="fitStart"
            android:visibility="gone"
            tools:ignore="ContentDescription" />

        <!-- Text title (fallback) -->
        <TextView
            android:id="@+id/carouselTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:shadowColor="#99000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            tools:text="Attack on Titan" />

        <!-- Metadata row: status · rating · genres -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/carouselStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ic_banner_background"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                tools:text="RELEASING" />

            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="8dp"
                android:background="#88FFFFFF" />

            <TextView
                android:id="@+id/carouselRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFDD44"
                android:textSize="13sp"
                tools:text="★ 9.0" />

            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="8dp"
                android:background="#88FFFFFF" />

            <TextView
                android:id="@+id/carouselGenres"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                tools:text="Action • Fantasy" />

        </LinearLayout>

        <!-- Synopsis -->
        <TextView
            android:id="@+id/carouselSynopsis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="#BBFFFFFF"
            android:textSize="13sp"
            tools:text="Centuries ago, mankind was slaughtered to near extinction by monstrous humanoid creatures called Titans…" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/carouselWatchButton"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:minWidth="120dp"
                android:paddingHorizontal="20dp"
                android:text="@string/watch_now"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
