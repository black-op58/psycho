<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Loading spinner -->
    <LinearLayout
        android:id="@+id/profileProgressBar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:visibility="gone"
        tools:visibility="gone">

        <ProgressBar
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Collapsing banner + avatar + username + followers pills (unchanged) -->
    <include layout="@layout/item_profile_app_bar" />

    <!-- ── Scrollable unified content ─────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ── AniList Account Card ──────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profileAnilistCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Banner background -->
                    <ImageView
                        android:id="@+id/profileAnilistBanner"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:scaleType="centerCrop"
                        tools:ignore="ContentDescription" />

                    <!-- Dark scrim over banner -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:background="#99000000" />

                    <!-- AniList icon on the left -->
                    <ImageView
                        android:id="@+id/profileAnilistIcon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:src="@drawable/ic_anilist"
                        tools:ignore="ContentDescription" />

                    <!-- Avatar on the right -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/profileAnilistCardAvatar"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Material3.ImageList.Circle"
                        tools:ignore="ContentDescription,ImageContrastCheck"
                        tools:src="@tools:sample/avatars" />

                    <!-- Center: username, expiry, logout button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/profileAnilistIcon"
                        android:layout_toStartOf="@id/profileAnilistCardAvatar"
                        android:orientation="vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="8dp">

                        <TextView
                            android:id="@+id/profileAnilistUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            tools:text="Sanin58" />

                        <TextView
                            android:id="@+id/profileAnilistExpiry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:textColor="#99ffffff"
                            android:textSize="11sp"
                            tools:text="Reconnect in 351 days" />

                        <TextView
                            android:id="@+id/profileAnilistLogout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/poppins_medium"
                            android:padding="2dp"
                            android:text="Logout"
                            android:textColor="#FF6B6B"
                            android:textSize="12sp" />
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── MAL Section ────────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/profileMalSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_myanimelist"
                    tools:ignore="ContentDescription" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/profileMalUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_semi_bold"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        tools:text="MyAnimeList" />

                    <TextView
                        android:id="@+id/profileMalLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_medium"
                        android:text="Login"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/profileMalAvatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:visibility="gone"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Material3.ImageList.Circle"
                    tools:ignore="ContentDescription,ImageContrastCheck" />
            </LinearLayout>

            <!-- ── Divider ─────────────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="16dp"
                android:background="?android:attr/listDivider" />

            <!-- ── AniList Settings Row ──────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/profileAnilistSettingsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_round_manage_accounts_24"
                    app:tint="?attr/colorPrimary"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/poppins_medium"
                    android:text="AniList Settings"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- ── Enable Comments Row ──────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/profileCommentsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_round_comment_24"
                    app:tint="?attr/colorPrimary"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/poppins_medium"
                    android:text="Enable Comments"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/profileCommentsSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- ── Divider ─────────────────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="16dp"
                android:background="?android:attr/listDivider" />

            <!-- ── Stats Section ─────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/profileStatsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:text="Stats"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp" />

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="1,3">

                    <TableRow android:padding="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:paddingEnd="16dp"
                            android:text="Episodes Watched"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/profileEpisodesWatched"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="13sp"
                            tools:text="5128" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Chapters Read"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/profileChaptersRead"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="13sp"
                            tools:text="126" />
                    </TableRow>

                    <TableRow android:padding="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:paddingEnd="16dp"
                            android:text="Days Watched"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/profileDaysWatched"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="13sp"
                            tools:text="85" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Volumes Read"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/profileVolumeRead"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="13sp"
                            tools:text="0" />
                    </TableRow>

                    <TableRow android:padding="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:paddingEnd="16dp"
                            android:text="Anime Mean Score"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/profileAnimeMeanScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="13sp"
                            tools:text="78.28" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Manga Mean Score"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/profileMangaMeanScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semi_bold"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="13sp"
                            tools:text="0.0" />
                    </TableRow>
                </TableLayout>
            </LinearLayout>

            <!-- ── Favourite Anime ───────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/profileFavAnimeSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:text="Favourite Anime"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/profileFavAnimeRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    tools:ignore="SpeakableTextPresentCheck" />
            </LinearLayout>

            <!-- ── Favourite Characters ──────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/profileFavCharactersSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="@font/poppins_semi_bold"
                    android:text="Favourite Characters"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/profileFavCharactersRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    tools:ignore="SpeakableTextPresentCheck" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Compat anchor: keeps StatsFragment's setBaseline() call from crashing -->
    <View
        android:id="@+id/profileNavBarContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="bottom"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
