<?xml version="1.0" encoding="utf-8"?>
<!--
  Navigating Banner overlay — shown inside homeNavigatingBannerContainer.
  The two ImageViews (navBannerBgA / navBannerBgB) cross-fade when the user's
  D-pad focus moves to a different anime card.  The content overlay (logo,
  status, rating, genres, synopsis, button) slides up from the bottom.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Banner image A (visible initially / after fade-in) -->
    <ImageView
        android:id="@+id/navBannerBgA"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        tools:ignore="ContentDescription"
        tools:src="@tools:sample/backgrounds/scenic" />

    <!-- Banner image B (fades in on top of A, then A is hidden) -->
    <ImageView
        android:id="@+id/navBannerBgB"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:scaleType="centerCrop"
        tools:ignore="ContentDescription" />

    <!-- Dark gradient — bottom-heavy so content text remains readable -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/linear_gradient_bg" />

    <!-- Content overlay at the bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="20dp">

        <!-- TMDB logo art (shown when available, hides text title) -->
        <ImageView
            android:id="@+id/navBannerLogo"
            android:layout_width="160dp"
            android:layout_height="56dp"
            android:scaleType="fitStart"
            android:visibility="gone"
            tools:ignore="ContentDescription" />

        <!-- Text title (fallback when no TMDB logo) -->
        <TextView
            android:id="@+id/navBannerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:shadowColor="#99000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="4"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            tools:text="Attack on Titan" />

        <!-- Meta row: status  ·  rating  ·  genres -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/navBannerStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ic_banner_background"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                tools:text="FINISHED" />

            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="8dp"
                android:background="#88FFFFFF" />

            <TextView
                android:id="@+id/navBannerRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFDD44"
                android:textSize="13sp"
                tools:text="★ 9.0" />

            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="8dp"
                android:background="#88FFFFFF" />

            <TextView
                android:id="@+id/navBannerGenres"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                tools:text="Action • Fantasy" />

        </LinearLayout>

        <!-- Synopsis -->
        <TextView
            android:id="@+id/navBannerSynopsis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="#BBFFFFFF"
            android:textSize="13sp"
            tools:text="Centuries ago, mankind was slaughtered to near extinction by monstrous humanoid creatures called Titans…" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/navBannerWatchBtn"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:minWidth="120dp"
                android:paddingHorizontal="20dp"
                android:text="@string/watch_now"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
