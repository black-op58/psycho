    <!-- Pause Metadata Overlay (visible after 3s pausing) -->
    <FrameLayout
        android:id="@+id/exo_pause_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <!-- Left-side dark gradient background -->
        <View
            android:layout_width="250dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:background="@drawable/pause_gradient_bg" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="100dp"
            android:padding="24dp"
            android:maxHeight="85%"
            android:fadeScrollbars="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Anime Title -->
                <TextView
                    android:id="@+id/exo_pause_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@android:color/white"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:shadowColor="#CC000000"
                    android:shadowDx="1"
                    android:shadowDy="1"
                    android:shadowRadius="4"
                    tools:text="Attack on Titan" />

                <!-- Rating Row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="#FFD700"
                        android:textSize="18sp"
                        android:text="★ "
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:id="@+id/exo_pause_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="#FFD700"
                        android:textSize="18sp"
                        tools:text="86%" />

                    <TextView
                        android:id="@+id/exo_pause_score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="@font/poppins"
                        android:textColor="#B0FFFFFF"
                        android:textSize="13sp"
                        tools:text="Score" />
                </LinearLayout>

                <!-- Genres Tags -->
                <TextView
                    android:id="@+id/exo_pause_genres"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/poppins"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    tools:text="Action • Drama • Fantasy • Supernatural" />

                <!-- Synopsis -->
                <TextView
                    android:id="@+id/exo_pause_synopsis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/poppins"
                    android:textColor="#E0FFFFFF"
                    android:textSize="14sp"
                    android:lineSpacingExtra="6dp"
                    android:maxLines="12"
                    android:ellipsize="end"
                    tools:text="In a world where humanity lives inside cities surrounded by enormous walls..." />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>
    </FrameLayout>
</FrameLayout>