<?xml version="1.0" encoding="utf-8"?>
<!--
    Hero "Continue Watching" card — full-width, landscape aspect.
    Shows banner/screenshot backdrop with resume info overlaid.
    D-pad navigable for Android TV.
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/heroCard"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="14dp"
    app:cardElevation="8dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Banner / screenshot backdrop -->
        <ImageView
            android:id="@+id/heroBanner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            tools:src="@tools:sample/backgrounds/scenic" />

        <!-- Screenshot overlay (shown when screenshot setting is on) -->
        <ImageView
            android:id="@+id/heroScreenshot"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            android:visibility="gone" />

        <!-- Full gradient scrim for text legibility -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_overlay_bottom" />

        <!-- TMDB title logo (top-right, hidden until loaded) -->
        <ImageView
            android:id="@+id/heroLogo"
            android:layout_width="160dp"
            android:layout_height="72dp"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:alpha="0f"
            android:contentDescription="@null"
            android:scaleType="fitEnd" />

        <!-- Left strip: cover thumbnail -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/heroCover"
            android:layout_width="90dp"
            android:layout_height="130dp"
            android:layout_gravity="bottom|start"
            android:layout_margin="16dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/roundedImageView"
            tools:ignore="ContentDescription"
            tools:srcCompat="@tools:sample/avatars" />

        <!-- Right side: info panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="122dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="14dp"
            android:orientation="vertical">

            <!-- Label chip -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_accent"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="▷  Continue Watching"
                android:textColor="#FFFFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                tools:ignore="TextContrastCheck" />

            <!-- Title -->
            <TextView
                android:id="@+id/heroTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:ignore="TextContrastCheck"
                tools:text="Attack on Titan: Final Season" />

            <!-- Episode -->
            <TextView
                android:id="@+id/heroEpisode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                tools:ignore="TextContrastCheck"
                tools:text="Episode 12 of 24" />

            <!-- Minutes remaining + next ep row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/heroMinutesRemaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_dark"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textColor="#AAFFFFFF"
                    android:textSize="10sp"
                    android:visibility="gone"
                    tools:ignore="TextContrastCheck"
                    tools:text="~288 min remaining"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/heroNextEp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_pill_dark"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textColor="#AAFFFFFF"
                    android:textSize="10sp"
                    android:visibility="gone"
                    tools:ignore="TextContrastCheck"
                    tools:text="Ep 13 in 2d 4h"
                    tools:visibility="visible" />

                <!-- Source memory indicator -->
                <TextView
                    android:id="@+id/heroSourceMemory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_pill_dark"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textColor="#AAFFFFFF"
                    android:textSize="10sp"
                    android:visibility="gone"
                    tools:ignore="TextContrastCheck"
                    tools:text="↩ Source remembered"
                    tools:visibility="visible" />

            </LinearLayout>

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/heroProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="8dp"
                android:max="100"
                android:backgroundTint="#44FFFFFF"
                android:progressTint="@color/violet_400"
                tools:ignore="UnusedAttribute"
                tools:progress="50" />

        </LinearLayout>

    </FrameLayout>

</androidx.cardview.widget.CardView>
