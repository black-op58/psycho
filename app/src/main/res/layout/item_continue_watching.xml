<?xml version="1.0" encoding="utf-8"?>
<!--
    Regular "Continue Watching" row item.
    Portrait card with progress bar, episode info, minutes remaining,
    and next episode air date. D-pad navigable for Android TV.
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="120dp"
    android:layout_height="200dp"
    android:layout_marginEnd="10dp"
    android:clickable="true"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Cover art -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/cwCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/roundedImageView"
            tools:ignore="ContentDescription,ImageContrastCheck"
            tools:srcCompat="@tools:sample/backgrounds/scenic" />

        <!-- Bottom gradient overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_overlay_bottom" />

        <!-- Info panel at bottom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/cwTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="#FFFFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:ignore="TextContrastCheck"
                tools:text="Anime Title" />

            <TextView
                android:id="@+id/cwEpisode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:layout_marginTop="1dp"
                tools:ignore="TextContrastCheck"
                tools:text="Ep 12 of 24" />

            <!-- Minutes remaining -->
            <TextView
                android:id="@+id/cwMinutesRemaining"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#99FFFFFF"
                android:textSize="8sp"
                android:layout_marginTop="1dp"
                android:visibility="gone"
                tools:ignore="TextContrastCheck"
                tools:text="~288 min left"
                tools:visibility="visible" />

            <!-- Next episode air date -->
            <TextView
                android:id="@+id/cwNextEp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#99FFFFFF"
                android:textSize="8sp"
                android:layout_marginTop="1dp"
                android:visibility="gone"
                tools:ignore="TextContrastCheck"
                tools:text="Ep 13 in 2d 4h"
                tools:visibility="visible" />

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/cwProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="5dp"
                android:max="100"
                android:progress="45"
                android:progressTint="@color/violet_400"
                android:backgroundTint="#55FFFFFF"
                tools:ignore="UnusedAttribute" />
        </LinearLayout>

    </FrameLayout>

</androidx.cardview.widget.CardView>
